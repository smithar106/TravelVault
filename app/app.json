{
  "expo": {
    "name": "TravelVault",
    "slug": "travelvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "travelvault",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0D6B6B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelvault.app",
      "infoPlist": {
        "UIUserInterfaceStyle": "Light"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D6B6B"
      },
      "package": "com.travelvault.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0D6B6B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "REVENUECAT_API_KEY": "REVENUECAT_API_KEY",
      "POSTHOG_API_KEY": "POSTHOG_API_KEY",
      "SUPABASE_URL": "SUPABASE_URL",
      "SUPABASE_ANON_KEY": "SUPABASE_ANON_KEY",
      "TRAVELVAULT_QUIZ_URL": "TRAVELVAULT_QUIZ_URL",
      "API_URL": "API_URL",
      "eas": {
        "projectId": ""
      }
    }
  }
}
